#!/usr/bin/env bash
# dhcedge — manage the digitalhome.edge Docker Compose stack.
#
# The whole edge runs as one systemd oneshot (dhe.service) that drives
# `docker compose up -d/down` against /opt/dhe/docker-compose.yml.
#
# Usage:
#   dhcedge status              Show service state + container health
#   dhcedge start               Start the stack
#   dhcedge stop                Stop the stack
#   dhcedge restart             Restart the stack
#   dhcedge logs [service]      Tail container logs (default: node-red)
#   dhcedge update-hosts        Generate /etc/hosts entries from config cache
#   dhcedge show-config         Show config cache (secrets redacted)
#   dhcedge show-secrets        Print MCP token + Node-RED credentials (sudo)

set -euo pipefail

DHE_ROOT="/opt/dhe"
COMPOSE_FILE="${DHE_ROOT}/docker-compose.yml"
CONFIG_CACHE="${DHE_ROOT}/config/dhe.config.cache"
HOSTS_MARKER_BEGIN="# >>> digitalhome-edge managed block — do not edit manually >>>"
HOSTS_MARKER_END="# <<< digitalhome-edge managed block <<<"

# ── helpers ──────────────────────────────────────────────────────────────────

die()  { echo "ERROR: $*" >&2; exit 1; }

require_sudo() {
    if [[ $EUID -ne 0 ]]; then
        die "This command requires sudo. Run: sudo dhcedge $*"
    fi
}

# ── commands ─────────────────────────────────────────────────────────────────

cmd_status() {
    echo "digitalhome.edge"
    echo ""
    local unit_state
    unit_state="$(systemctl is-active dhe.service 2>/dev/null || true)"
    printf "  systemd (dhe.service)   %s\n" "$unit_state"
    echo ""
    if command -v docker &>/dev/null; then
        docker compose -f "$COMPOSE_FILE" ps 2>&1 || true
    fi
}

cmd_start() {
    require_sudo "$@"
    systemctl start dhe.service
    cmd_status
}

cmd_stop() {
    require_sudo "$@"
    systemctl stop dhe.service
    cmd_status
}

cmd_restart() {
    require_sudo "$@"
    systemctl restart dhe.service
    cmd_status
}

cmd_logs() {
    local target="${1:-node-red}"
    if [[ "$target" == "all" ]]; then
        docker compose -f "$COMPOSE_FILE" logs -f
    else
        docker logs -f "dhe-${target#dhe-}" 2>&1
    fi
}

cmd_update_hosts() {
    require_sudo "update-hosts"
    command -v python3 &>/dev/null || die "python3 is required but not found."
    [[ -f "$CONFIG_CACHE" ]] || die "Config cache not found: ${CONFIG_CACHE}\nRun deploy/bootstrap.sh first."

    local entries
    entries=$(python3 -c "
import json, sys
with open('${CONFIG_CACHE}') as f:
    cfg = json.load(f)
devices = cfg.get('devices', {})
for hostname, info in devices.items():
    ip = info.get('ip', '')
    if ip:
        print(f'{ip}    {hostname}')
")

    local block
    block="${HOSTS_MARKER_BEGIN}"$'\n'
    block+="127.0.0.1       digitalhome-edge"$'\n'
    if [[ -n "$entries" ]]; then
        block+="${entries}"$'\n'
    else
        echo "WARN: No devices in config cache. Only self-reference written."
    fi
    block+="${HOSTS_MARKER_END}"

    local hosts_file="/etc/hosts"
    local tmp
    tmp=$(mktemp)
    sed "/${HOSTS_MARKER_BEGIN//\//\\/}/,/${HOSTS_MARKER_END//\//\\/}/d" "$hosts_file" > "$tmp"
    printf '\n%s\n' "$block" >> "$tmp"
    cp "$tmp" "$hosts_file"
    rm -f "$tmp"

    echo "Updated ${hosts_file}:"
    sed -n "/${HOSTS_MARKER_BEGIN//\//\\/}/,/${HOSTS_MARKER_END//\//\\/}/p" "$hosts_file"
}

cmd_show_config() {
    [[ -f "$CONFIG_CACHE" ]] || die "Config cache not found: ${CONFIG_CACHE}"

    python3 -c "
import json
with open('${CONFIG_CACHE}') as f:
    cfg = json.load(f)

REDACTED_KEYS = {
    'api_key', 'credential_secret', 'auth_token',
    'admin_password', 'http_password', 'password',
}

def redact(obj):
    if isinstance(obj, dict):
        return {k: '***' if k in REDACTED_KEYS and v else redact(v)
                for k, v in obj.items()}
    return obj

print(json.dumps(redact(cfg), indent=2))
"
}

cmd_show_secrets() {
    require_sudo "show-secrets"
    local secrets_dir="${DHE_ROOT}/secrets"
    [[ -d "$secrets_dir" ]] || die "Secrets directory not found: ${secrets_dir}"

    local mcp_token nodered_admin_user nodered_admin_pw nodered_http_user nodered_http_pw
    mcp_token=$(cat "${secrets_dir}/mcp-auth-token" 2>/dev/null || echo "(unset)")
    nodered_admin_user=$(cat "${secrets_dir}/nodered-admin-user" 2>/dev/null || echo "admin")
    nodered_admin_pw=$(cat "${secrets_dir}/nodered-admin-password" 2>/dev/null || echo "(unset)")
    nodered_http_user=$(cat "${secrets_dir}/nodered-http-user" 2>/dev/null || echo "dhcedge")
    nodered_http_pw=$(cat "${secrets_dir}/nodered-http-password" 2>/dev/null || echo "(unset)")

    printf "MCP bearer token       %s\n" "$mcp_token"
    printf "Node-RED editor login  %s / %s\n" "$nodered_admin_user" "$nodered_admin_pw"
    printf "Node-RED /api/* login  %s / %s\n" "$nodered_http_user" "$nodered_http_pw"
    printf "\nUse in Claude Desktop config:\n"
    printf "  \"headers\": { \"Authorization\": \"Bearer %s\" }\n" "$mcp_token"
}

cmd_help() {
    echo "Usage: dhcedge <command>"
    echo ""
    echo "Commands:"
    echo "  status              Show systemd + container state"
    echo "  start               Start the stack (requires sudo)"
    echo "  stop                Stop the stack (requires sudo)"
    echo "  restart             Restart the stack (requires sudo)"
    echo "  logs [service]      Follow container logs (default: node-red)"
    echo "  update-hosts        Regenerate /etc/hosts from config cache (requires sudo)"
    echo "  show-config         Show config cache (secrets redacted)"
    echo "  show-secrets        Print MCP token + Node-RED credentials (requires sudo)"
    echo "  help                Show this help"
}

# ── main ─────────────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
    cmd_help
    exit 0
fi

case "$1" in
    status)       cmd_status ;;
    start)        cmd_start "$@" ;;
    stop)         cmd_stop "$@" ;;
    restart)      cmd_restart "$@" ;;
    logs)         shift; cmd_logs "${1:-node-red}" ;;
    update-hosts) cmd_update_hosts ;;
    show-config)  cmd_show_config ;;
    show-secrets) cmd_show_secrets ;;
    help|-h|--help) cmd_help ;;
    *) die "Unknown command: $1 (run 'dhcedge help')" ;;
esac
