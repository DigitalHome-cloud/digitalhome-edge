[Unit]
Description=digitalhome.edge Docker Compose stack
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/dhe
EnvironmentFile=-/opt/dhe/.env
ExecStart=/usr/bin/docker compose -f /opt/dhe/docker-compose.yml up -d
ExecStop=/usr/bin/docker compose -f /opt/dhe/docker-compose.yml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
