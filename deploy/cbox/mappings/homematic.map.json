{
    "source": "ccu",
    "tbox": "Brick+extensions.ttl",
    "version": "0.2.0",
    "note": "Homematic CCU (node-red-contrib-ccu) datapoint names -> T-BOX. Migrated from the inline dhc:sourceMap/ccu/* entries in abox.jsonld (behaviour-preserving). Source key stays 'ccu' to match the normalizer output. + electrical (current/voltage/frequency), valve, battery-state, humidity, mode, fault, RSSI.",
    "capabilities": {
        "on": {
            "brickClass": "brick:On_Off_Command",
            "valueType": "xsd:boolean"
        },
        "brightness": {
            "brickClass": "brick:Luminance_Sensor",
            "valueType": "xsd:double",
            "unit": "unit:PERCENT"
        },
        "temperature": {
            "brickClass": "brick:Temperature_Sensor",
            "valueType": "xsd:double",
            "unit": "unit:DEG_C"
        },
        "setpoint": {
            "brickClass": "brick:Temperature_Setpoint",
            "valueType": "xsd:double",
            "unit": "unit:DEG_C"
        },
        "humidity": {
            "brickClass": "brick:Relative_Humidity_Sensor",
            "valueType": "xsd:double",
            "unit": "unit:PERCENT"
        },
        "illuminance": {
            "brickClass": "brick:Illuminance_Sensor",
            "valueType": "xsd:double",
            "unit": "unit:LUX"
        },
        "motion": {
            "brickClass": "brick:Occupancy_Sensor",
            "valueType": "xsd:boolean"
        },
        "battery": {
            "brickClass": "brick:Battery_Voltage_Sensor",
            "valueType": "xsd:double",
            "unit": "unit:PERCENT"
        },
        "reachable": {
            "brickClass": "brick:Availability_Status",
            "valueType": "xsd:boolean"
        },
        "window_open": {
            "brickClass": "brick:Contact_Sensor",
            "valueType": "xsd:boolean"
        },
        "power": {
            "brickClass": "brick:Power_Sensor",
            "valueType": "xsd:double",
            "unit": "unit:W"
        },
        "energy": {
            "brickClass": "brick:Energy_Sensor",
            "valueType": "xsd:double",
            "unit": "unit:KiloW-HR"
        },
        "current": {
            "brickClass": "brick:Current_Sensor",
            "valueType": "xsd:double",
            "unit": "unit:A"
        },
        "voltage": {
            "brickClass": "brick:Voltage_Sensor",
            "valueType": "xsd:double",
            "unit": "unit:V"
        },
        "frequency": {
            "brickClass": "brick:Frequency_Sensor",
            "valueType": "xsd:double",
            "unit": "unit:HZ"
        },
        "valve_position": {
            "brickClass": "brick:Valve_Position_Sensor",
            "valueType": "xsd:double",
            "unit": "unit:PERCENT"
        },
        "operating_mode": {
            "brickClass": "brick:Operating_Mode_Status",
            "valueType": "xsd:integer"
        },
        "fault": {
            "brickClass": "brick:Fault_Status",
            "valueType": "xsd:boolean"
        },
        "signal_strength": {
            "brickClass": "dhc:Signal_Strength_Sensor",
            "valueType": "xsd:double",
            "unit": "unit:DeciB-M"
        }
    },
    "fields": {
        "STATE": {
            "capability": "on"
        },
        "LEVEL": {
            "capability": "brightness",
            "coerce": "unit-to-percent"
        },
        "TEMPERATURE": {
            "capability": "temperature"
        },
        "ACTUAL_TEMPERATURE": {
            "capability": "temperature"
        },
        "SET_TEMPERATURE": {
            "capability": "setpoint"
        },
        "SET_POINT_TEMPERATURE": {
            "capability": "setpoint"
        },
        "HUMIDITY": {
            "capability": "humidity"
        },
        "ILLUMINATION": {
            "capability": "illuminance"
        },
        "BRIGHTNESS": {
            "capability": "illuminance"
        },
        "MOTION": {
            "capability": "motion"
        },
        "PRESENCE_DETECTION_STATE": {
            "capability": "motion"
        },
        "OPERATING_VOLTAGE": {
            "capability": "battery"
        },
        "LOWBAT": {
            "capability": "battery",
            "coerce": "invert-boolean"
        },
        "UNREACH": {
            "capability": "reachable",
            "coerce": "invert-boolean"
        },
        "STATE_WINDOW": {
            "capability": "window_open"
        },
        "POWER": {
            "capability": "power"
        },
        "ENERGY_COUNTER": {
            "capability": "energy",
            "coerce": "wh-to-kwh"
        },
        "CURRENT": {
            "capability": "current",
            "coerce": "milli-to-unit"
        },
        "VOLTAGE": {
            "capability": "voltage"
        },
        "FREQUENCY": {
            "capability": "frequency"
        },
        "VALVE_STATE": {
            "capability": "valve_position"
        },
        "BATTERY_STATE": {
            "capability": "battery"
        },
        "ACTUAL_HUMIDITY": {
            "capability": "humidity"
        },
        "CONTROL_MODE": {
            "capability": "operating_mode"
        },
        "FAULT_REPORTING": {
            "capability": "fault"
        },
        "ERROR_OVERHEAT": {
            "capability": "fault"
        },
        "RSSI_DEVICE": {
            "capability": "signal_strength"
        },
        "RSSI_PEER": {
            "capability": "signal_strength"
        }
    }
}
