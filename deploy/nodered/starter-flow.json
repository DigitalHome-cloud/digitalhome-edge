[
    {
        "id": "dhe-tab-main",
        "type": "tab",
        "label": "digitalhome.edge",
        "disabled": false,
        "info": "Starter flow seeded on first boot. Contains:\n\n- mcp-server-config on :8443 with a hello_world tool for MCP wire smoke testing\n- dhc-sync-config that drives the OAuth device flow against digitalhome.cloud\n- dashboard tabs (Setup / Status) showing the pairing QR code and live status\n\nSafe to modify or delete. Not overwritten on subsequent boots."
    },

    {
        "id": "dhe-mcp-cfg",
        "type": "mcp-server-config",
        "name": "MCP server",
        "mcpPath": "/mcp",
        "mcpHost": "0.0.0.0",
        "mcpPort": "8443",
        "tokenFile": "/secrets/mcp-auth-token",
        "cboxPath": "/cbox/cbox.jsonld",
        "serverName": "digitalhome-edge",
        "serverVer": "0.1.0"
    },

    {
        "id": "dhe-tool-hello",
        "type": "mcp-tool-in",
        "z": "dhe-tab-main",
        "name": "hello_world",
        "server": "dhe-mcp-cfg",
        "toolName": "hello_world",
        "description": "Return a friendly greeting. Verifies the MCP wire end to end.",
        "inputSchema": "{\"type\":\"object\",\"properties\":{\"text\":{\"type\":\"string\",\"description\":\"who to greet\"}},\"required\":[]}",
        "x": 140,
        "y": 100,
        "wires": [["dhe-fn-greet"]]
    },
    {
        "id": "dhe-fn-greet",
        "type": "function",
        "z": "dhe-tab-main",
        "name": "greet",
        "func": "const name = (msg.payload && msg.payload.text) || 'world';\nmsg.payload = { greeting: `hello ${name}!`, from: 'digitalhome.edge' };\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 100,
        "wires": [["dhe-resp-hello"]]
    },
    {
        "id": "dhe-resp-hello",
        "type": "mcp-response",
        "z": "dhe-tab-main",
        "name": "",
        "server": "dhe-mcp-cfg",
        "errorFlag": false,
        "x": 500,
        "y": 100,
        "wires": []
    },

    {
        "id": "dhe-sync-cfg",
        "type": "dhc-sync-config",
        "name": "cloud sync",
        "cloudApiUrl": "https://api.digitalhome.cloud/edge/v1",
        "clientId": "digitalhome-edge",
        "scope": "edge.link edge.telemetry edge.cbox edge.lake",
        "secretsDir": "/secrets",
        "configDir": "/config"
    },

    {
        "id": "dhe-ui-base",
        "type": "ui-base",
        "name": "digitalhome.edge",
        "path": "/dashboard",
        "appIcon": "",
        "includeClientData": true,
        "acceptsClientConfig": [],
        "showPathInSidebar": false,
        "showPageTitle": true,
        "navigationStyle": "default"
    },
    {
        "id": "dhe-ui-page-setup",
        "type": "ui-page",
        "name": "Setup",
        "ui": "dhe-ui-base",
        "path": "/setup",
        "icon": "link-variant",
        "layout": "grid",
        "theme": "",
        "order": 1,
        "className": "",
        "visible": "true",
        "disabled": "false"
    },
    {
        "id": "dhe-ui-page-status",
        "type": "ui-page",
        "name": "Status",
        "ui": "dhe-ui-base",
        "path": "/",
        "icon": "home",
        "layout": "grid",
        "theme": "",
        "order": 2,
        "className": "",
        "visible": "true",
        "disabled": "false"
    },
    {
        "id": "dhe-ui-grp-pairing",
        "type": "ui-group",
        "name": "Pairing",
        "page": "dhe-ui-page-setup",
        "width": "12",
        "height": "1",
        "order": 1,
        "showTitle": false,
        "className": "",
        "visible": "true",
        "disabled": "false"
    },
    {
        "id": "dhe-ui-grp-linked",
        "type": "ui-group",
        "name": "Edge status",
        "page": "dhe-ui-page-status",
        "width": "12",
        "height": "1",
        "order": 1,
        "showTitle": false,
        "className": "",
        "visible": "true",
        "disabled": "false"
    },

    {
        "id": "dhe-sync-status",
        "type": "dhc-sync-status",
        "z": "dhe-tab-main",
        "name": "sync state",
        "sync": "dhe-sync-cfg",
        "x": 140,
        "y": 220,
        "wires": [["dhe-fn-normalize"]]
    },
    {
        "id": "dhe-fn-normalize",
        "type": "function",
        "z": "dhe-tab-main",
        "name": "normalize for UI",
        "func": "const p = msg.payload || {};\nconst state = p.state || 'boot';\nconst statusText = {\n    boot:              'Starting…',\n    unlinked:          'Reaching digitalhome.cloud…',\n    awaiting_approval: 'Waiting for your approval on your phone…',\n    linked:            'Linked ✓',\n    denied:            'Pairing denied. Tap Restart to try again.',\n    error:             p.error || 'Something went wrong. Tap Restart.'\n}[state] || state;\nmsg.payload = { ...p, status_text: statusText };\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 330,
        "y": 220,
        "wires": [["dhe-tmpl-setup", "dhe-tmpl-status"]]
    },
    {
        "id": "dhe-tmpl-setup",
        "type": "ui-template",
        "z": "dhe-tab-main",
        "group": "dhe-ui-grp-pairing",
        "page": "",
        "ui": "",
        "name": "Setup card",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n    <v-card v-if=\"msg?.payload && msg.payload.state !== 'linked'\" flat>\n        <v-card-title>\n            <span v-if=\"msg.payload.state === 'awaiting_approval'\">Approve this edge</span>\n            <span v-else-if=\"msg.payload.state === 'denied'\">Pairing denied</span>\n            <span v-else>Preparing pairing…</span>\n        </v-card-title>\n\n        <v-card-text v-if=\"msg.payload.state === 'awaiting_approval'\">\n            <p>Scan on your phone, or open the URL in any browser:</p>\n            <div class=\"qr-wrap\" v-html=\"msg.payload.qr_svg\"></div>\n            <p style=\"word-break: break-all;\">\n                <a :href=\"msg.payload.verification_uri_complete\" target=\"_blank\">\n                    {{ msg.payload.verification_uri_complete }}\n                </a>\n            </p>\n            <p>Or enter this code manually:</p>\n            <h2 class=\"user-code\">{{ msg.payload.user_code }}</h2>\n            <p class=\"status-text\">{{ msg.payload.status_text }}</p>\n        </v-card-text>\n\n        <v-card-text v-else>\n            <p class=\"status-text\">{{ msg.payload.status_text }}</p>\n        </v-card-text>\n\n        <v-card-actions v-if=\"msg.payload.state === 'denied' || msg.payload.state === 'error'\">\n            <v-btn color=\"primary\" @click=\"restart\">Restart pairing</v-btn>\n        </v-card-actions>\n    </v-card>\n</template>\n\n<script>\nexport default {\n    methods: {\n        restart() {\n            fetch('/dhc-sync/command', {\n                method: 'POST',\n                headers: { 'Content-Type': 'application/json' },\n                body: JSON.stringify({ action: 'restart' })\n            }).catch((e) => console.warn('restart failed', e));\n        }\n    }\n};\n</script>\n\n<style scoped>\n.qr-wrap { max-width: 300px; margin: 1em 0; }\n.qr-wrap :deep(svg) { width: 100%; height: auto; }\n.user-code { font-family: monospace; letter-spacing: 0.2em; text-align: center; }\n.status-text { color: rgba(0,0,0,0.6); font-style: italic; }\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 550,
        "y": 200,
        "wires": [[]]
    },
    {
        "id": "dhe-tmpl-status",
        "type": "ui-template",
        "z": "dhe-tab-main",
        "group": "dhe-ui-grp-linked",
        "page": "",
        "ui": "",
        "name": "Linked status card",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n    <v-card v-if=\"msg?.payload && msg.payload.state === 'linked'\" flat>\n        <v-card-title>Linked</v-card-title>\n        <v-card-text>\n            <v-list density=\"compact\">\n                <v-list-item>\n                    <v-list-item-title>Home</v-list-item-title>\n                    <v-list-item-subtitle>{{ msg.payload.home_id }}</v-list-item-subtitle>\n                </v-list-item>\n                <v-list-item>\n                    <v-list-item-title>Edge ID</v-list-item-title>\n                    <v-list-item-subtitle>{{ msg.payload.edge_id }}</v-list-item-subtitle>\n                </v-list-item>\n                <v-list-item v-if=\"msg.payload.last_telemetry_at\">\n                    <v-list-item-title>Last telemetry</v-list-item-title>\n                    <v-list-item-subtitle>{{ msg.payload.last_telemetry_at }}</v-list-item-subtitle>\n                </v-list-item>\n            </v-list>\n        </v-card-text>\n    </v-card>\n</template>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 550,
        "y": 240,
        "wires": [[]]
    }
]
